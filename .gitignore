# .gitignore - Git Ignore Rules for EV ECU Project
#
# Files listed here are NOT tracked by git.
# This keeps the repository clean - only source code, not build outputs.
#
# Rule of thumb: If it can be GENERATED from source code, ignore it.
#                If it's SOURCE CODE or CONFIG, track it.

# --- Build outputs -----------------------------------------------------
# The build/ directory is generated by CMake + the compiler
# Never commit binary files - they change every build and bloat the repo
build/
Build/
out/

# Compiled firmware files
*.elf
*.bin
*.hex
*.map
*.lst
*.o
*.a
*.d

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
_deps/

# --- IDE and Editor files -----------------------------------------
# VS Code workspace settings that are personal (not shared)
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/c_cpp_properties.json

# STM32CubeIDE project files (personal workspace)
.project
.cproject
.settings/
Debug/
Release/

# CLion
.idea/
cmake-build-*/

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# --- Operating System files ---------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverrides
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*

# --- Tool-generated files ------------------------------------------
# Cppcheck
cppcheck-report.xml
build/cppcheck/
build/cppcheck-cache/

# Coverage reports
*.gcov
*.gcda
*.gcno
coverage/
lcov.info

# Test results
test-results.xml
test_output.txt

# Snyk
.snyk

# --- Dependency and package manager files -------------------------------
# Node (if any tooling scripts use npm)
node_modules/
npm-debug.log*

# Python (if any utility scripts use Python)
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# --- Documentation build outputs ---------------------------------------------
# Doxygen generated HTML (source .dox files are tracked, outputs are not)
html/
latex/
doxygen_output/

# --- Sensitive files - NEVER commit these -----------------------------------
# Private keys, tokens, passwords
*.pem
*.key
*.p12
*.pfx
secrets.h
credentials.h
.env.local

# --- Wokwi licence file (personal, not team) ----------------------------------
Simulation/wokwi/.wokwi_license

# --- Exceptions - files to track DESPITE matching patterns above ---------------
# Keep these even though their folders might be ignored
!.github/
!.github/**
!.gitkeep
